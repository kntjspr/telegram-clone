# get these from https://my.telegram.org
API_ID=
API_HASH=

# your phone number with country code (e.g. +1234567890)
PHONE=

# source channel to clone from (username or numeric ID)
SOURCE_CHANNEL=

# destination channel to clone into (username or numeric ID)
DEST_CHANNEL=

# tracker backend: "json" (default, local file), "sqlite" (local db), or "supabase" (remote db)
TRACKER_BACKEND=json

# sqlite settings (only if TRACKER_BACKEND=sqlite)
SQLITE_DB=clone_tracker.db

# supabase settings (only if TRACKER_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_KEY=

# send telegram notifications to Saved Messages on error/completion (true/false)
NOTIFY_ON_ERROR=true
NOTIFY_ON_COMPLETE=true
